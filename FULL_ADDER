Source Code : Behavioural Modelling

module fulladder_behaviouralmodelling(sum,carry,a,b,cin);
output sum,carry;
input a,b,cin;
reg sum,carry;
always @(a or b or cin)
{carry,sum} = a + b + cin;     
endmodule

