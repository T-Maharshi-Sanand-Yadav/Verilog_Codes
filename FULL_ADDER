Source Code : Data Flow Modelling

module fulladder_dataflowmodelling(sum,carry,a,b,cin);
output sum;
output carry;
input a;
input b;
input cin;
assign sum = a ^ b ^ cin;	//concurrent dataflow
assign carry = (a & b) | (b & cin) | (cin & a);
endmodule

Test Bench : Data Flow Modelling

module fulladder_dataflowmodelling_tb;

	// Inputs
	reg a;
	reg b;
	reg cin;

	// Outputs
	wire sum;
	wire carry;

	// Instantiate the Unit Under Test (UUT)
	fulladder_dataflowmodelling uut (
		.sum(sum), 
		.carry(carry), 
		.a(a), 
		.b(b), 
		.cin(cin)
	);

	initial 
	begin
	$monitor($time,"carry=%b,sum=%b,a=%b,b=%b,cin=%b",carry,sum,a,b,cin);
		// Initialize Inputs
		a = 0;
		b = 0;
		cin = 0;
	end
	always #20 a = a + 1;
	always #10 b = b + 1;
	always #5 cin = cin + 1;
      
endmodule


