Source Code : Gate Level Modelling
module fulladder(sum,cout,a,b,cin);
output sum;
output cout;
input a;
input b;
input cin;
wire w1,w2,w3;
xor x1(w1,a,b);
and x2(w2,a,b);
xor x3(sum,w1,cin);
and x4(w3,w1,cin);
or x5(cout,w2,w3);
endmodule

